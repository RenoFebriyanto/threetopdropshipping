{% layout 'theme' %}

{%- comment -%}
	templates/page.privacy.liquid
	------------------------------------------------------------
	Page ini digunakan untuk template custom Privacy Policy.
	Konten yang terlihat di website diambil dari "Page body" di Online Store > Pages.

	Jangan hardcode teks Privacy Policy langsung di template.
	Jika kamu mengedit halaman Privacy Policy lewat Shopify Admin, pastikan
	halaman tersebut memakai template "page.privacy".

	Gunakan page.title, page.updated_at, dan page.content agar konten tetap
	konsisten dan mudah diperbarui dari CMS.
{%- endcomment -%}

<main class="flex-grow" style="padding-top: 128px; padding-bottom: 120px;">
	<div style="max-width: 768px; margin: 0 auto; padding-left: 20px; padding-right: 20px;">

		<header style="text-align: center; margin-bottom: 120px;">
			<h1 style="font-family: 'Bodoni Moda', serif; font-size: 40px; font-weight: 400; letter-spacing: 0.05em; text-transform: uppercase; color: #000000; margin-bottom: 24px; line-height: 1.2;">{{ page.title }}</h1>
			<div style="width: 48px; height: 1px; background-color: #cfc4c5; margin: 0 auto;"></div>
			<p style="font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 400; line-height: 1.8; color: #4c4546; margin-top: 24px;">Last updated: {{ page.updated_at | date: "%B %-d, %Y" }}</p>
		</header>

		<article style="display: flex; flex-direction: column; gap: 48px;">
			<div style="font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 400; line-height: 1.6; color: #4c4546;">
				{{ page.content }}
			</div>
		</article>

		<style>
			article h2 {
				font-family: 'Bodoni Moda', serif;
				font-size: 24px;
				font-weight: 400;
				color: #000000;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				margin-top: 48px;
				margin-bottom: 24px;
				line-height: 1.4;
			}

			article p {
				font-family: 'Inter', sans-serif;
				font-size: 16px;
				font-weight: 400;
				color: #4c4546;
				line-height: 1.6;
				margin-bottom: 24px;
			}

			article ul,
			article ol {
				margin-left: 24px;
				margin-bottom: 24px;
				color: #4c4546;
				font-family: 'Inter', sans-serif;
				font-size: 16px;
				line-height: 1.6;
			}

			article li {
				margin-bottom: 12px;
			}

			article strong {
				font-weight: 500;
				color: #000000;
			}

			article a {
				color: #000000;
				text-decoration: underline;
			}
		</style>

	</div>
</main>