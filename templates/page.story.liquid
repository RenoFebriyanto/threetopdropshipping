{% layout 'theme' %}

<main class="pt-[120px] pb-stack-xl max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
<!-- Hero Section -->
<section class="min-h-[50vh] flex flex-col items-center justify-center text-center mb-stack-xl pt-stack-lg py-12 md:py-24">
<h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-primary tracking-tight max-w-4xl uppercase">
                Our Story
            </h1>
<div class="font-body-lg text-body-lg text-on-surface-variant mt-stack-md max-w-2xl font-light">
{{ page.content }}
</div>
</section>
<!-- Narrative Section (Asymmetric) -->
<section class="grid grid-cols-1 md:grid-cols-12 gap-gutter mb-stack-xl items-center py-12 md:py-24">
<div class="md:col-span-7 order-2 md:order-1 mt-stack-md md:mt-0">
<img alt="Fabric Texture" class="w-full h-auto object-cover aspect-[4/5] md:aspect-auto md:h-[800px]" data-alt="A close-up, highly detailed shot of folded, premium linen fabric. The lighting is soft and directional, highlighting the natural texture and weave of the material. The color palette is composed of warm off-whites and soft beige tones. The mood is serene, tactile, and luxurious, emphasizing high-end craftsmanship." src="https://lh3.googleusercontent.com/aida/AP1WRLv9if4wHThqwtAk_CNT2p00DSuQUExcUymT_wdt0URnszUvgi5Xyxq-CcBtE3z4CXe4LwdYItTaQEIJN4EUmzPS8O7TD80ENh7tWaQYV2sxat5j1QIhRybpBFNYHHOXXN3rl_t6-FhbjLM8LOajvDxAqcYCGxdperdWGZAZYHgkCahhQf_9fxfkYYM4NB4ffKUJ3AsfZzRZkkER55J04czf6V8Tcq3odpE29OO9j3R3Rets6nPym1Z2sX-m">
</div>
<div class="md:col-span-4 md:col-start-9 order-1 md:order-2 flex flex-col justify-center">
<h2 class="font-headline-md text-headline-md text-primary mb-6">The Philosophy of Less</h2>
<div class="space-y-6 font-body-md text-body-md text-on-surface-variant leading-relaxed">
<p>
                        At Lumina, we believe that true luxury whispers. It is found not in excess, but in the meticulous refinement of the essential. Our design language is rooted in modernist architecture, where form faithfully follows function, and every seam serves a purpose.
                    </p>
<p>
                        We strip away the superfluous to reveal the inherent beauty of raw, premium materials. The resulting silhouettes are structural yet fluid, designed to empower the wearer with a sense of calm confidence.
                    </p>
<p>
                        This is quiet luxury. An antidote to the ephemeral, built on a foundation of enduring quality and deliberate restraint.
                    </p>
</div>
</div>
</section>
<!-- Second Narrative Block (Two Column with Quote) -->
<section class="grid grid-cols-1 md:grid-cols-12 gap-gutter mb-stack-xl items-center py-stack-lg">
<div class="md:col-span-5 flex items-center justify-center p-8 md:p-0 mb-stack-md md:mb-0">
<blockquote class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-primary italic text-center md:text-left leading-tight">
                    "Elegance is refusal."
                </blockquote>
</div>
<div class="md:col-span-6 md:col-start-7">
<img alt="Cinematic Fashion Shot" class="w-full h-auto object-cover aspect-[4/5] md:h-[900px]" data-alt="A full-length fashion editorial shot of a model wearing minimalist, flowing beige silk garments. The model stands in a modern, stark concrete architectural space with strong, geometric shadows cast by natural sunlight. The aesthetic is highly structural, minimalist, and exudes quiet luxury. The color palette focuses on concrete greys, warm natural light, and the soft beige of the fabric." src="https://lh3.googleusercontent.com/aida/AP1WRLvZCvFCK2QO-pVGOmD3QSdqZghQiFEOUnvIR9YPv1DCR7szk64V1cPjyvSgQ-dJJ3pRnI9RSjzFf7F8e4Wehh1-JXA2-R6axPOWLeSLuZei8GQtd7yNGH2hpOcZ-UYEgc15X8__2K3jKsbXdC3KwZ_9OW80iMJt1vpeXeq98PVtRUh9s4ddfD53I8sQAjwrV4Ah6BjgDHWAOo5pc-tW9_kYgk-apL9E8L0T5o4rLMVHyOARgHHtNmfdxIQg">
</div>
</section>
<!-- Craftsmanship Section -->
<section class="max-w-3xl mx-auto text-center mb-stack-xl py-stack-lg">
<h2 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-primary mb-stack-md">Enduring Craftsmanship</h2>
<div class="grid grid-cols-1 md:grid-cols-2 gap-stack-md md:gap-gutter text-left">
<div>
<h3 class="font-label-sm text-label-sm text-primary uppercase tracking-widest mb-4 border-b border-outline-variant pb-2">Material Integrity</h3>
<p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
                         We source only the finest, low-impact materials. Our signature silks and structured wools are selected for their tactile superiority and longevity, ensuring each garment ages beautifully.
                     </p>
</div>
<div>
<h3 class="font-label-sm text-label-sm text-primary uppercase tracking-widest mb-4 border-b border-outline-variant pb-2">Conscious Construction</h3>
<p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
                         Produced in limited runs by master artisans, our production process prioritizes ethical labor and minimizes waste. Every stitch is a testament to our commitment to sustainable luxury.
                     </p>
</div>
</div>
</section>
</main>