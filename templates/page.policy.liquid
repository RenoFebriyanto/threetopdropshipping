{% layout 'theme' %}

{%- assign policy_title = '' -%}
{%- assign policy_body = '' -%}

{%- if page.title contains 'Shipping' -%}
  {%- assign policy_title = shop.shipping_policy.title -%}
  {%- assign policy_body = shop.shipping_policy.body -%}
{%- elsif page.title contains 'Privacy' -%}
  {%- assign policy_title = shop.privacy_policy.title -%}
  {%- assign policy_body = shop.privacy_policy.body -%}
{%- elsif page.title contains 'Refund' -%}
  {%- assign policy_title = shop.refund_policy.title -%}
  {%- assign policy_body = shop.refund_policy.body -%}
{%- elsif page.title contains 'Terms' -%}
  {%- assign policy_title = shop.terms_of_service.title -%}
  {%- assign policy_body = shop.terms_of_service.body -%}
{%- else -%}
  {%- assign policy_title = page.title -%}
  {%- assign policy_body = page.content -%}
{%- endif -%}

<main class="flex-grow" style="padding-top: 128px; padding-bottom: 120px;">
  <div style="max-width: 768px; margin: 0 auto; padding-left: 20px; padding-right: 20px;">
    <!-- Policy Title Header -->
    <header style="text-align: center; margin-bottom: 120px;">
      <h1 style="font-family: 'Bodoni Moda', serif; font-size: 40px; font-weight: 400; letter-spacing: 0.05em; text-transform: uppercase; color: #000000; margin-bottom: 24px; line-height: 1.2;">{{ policy_title }}</h1>
      <div style="width: 48px; height: 1px; background-color: #cfc4c5; margin: 0 auto;"></div>
    </header>

    <!-- Policy Content -->
    <article style="display: flex; flex-direction: column; gap: 48px;">
      <div style="font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 400; line-height: 1.6; color: #4c4546;">
        {{ policy_body }}
      </div>
    </article>

    <!-- Additional styling for nested elements -->
    <style>
      article h2 {
        font-family: 'Bodoni Moda', serif;
        font-size: 24px;
        font-weight: 400;
        color: #000000;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-top: 48px;
        margin-bottom: 24px;
        line-height: 1.4;
      }
      
      article p {
        font-family: 'Inter', sans-serif;
        font-size: 16px;
        font-weight: 400;
        color: #4c4546;
        line-height: 1.6;
        margin-bottom: 24px;
      }
      
      article ul {
        list-style-type: disc;
        margin-left: 24px;
        margin-bottom: 24px;
        color: #4c4546;
        font-family: 'Inter', sans-serif;
        font-size: 16px;
        line-height: 1.6;
      }
      
      article ol {
        list-style-type: decimal;
        margin-left: 24px;
        margin-bottom: 24px;
        color: #4c4546;
        font-family: 'Inter', sans-serif;
        font-size: 16px;
        line-height: 1.6;
      }
      
      article li {
        margin-bottom: 12px;
      }
      
      article strong {
        font-weight: 500;
      }
    </style>
  </div>
</main>
