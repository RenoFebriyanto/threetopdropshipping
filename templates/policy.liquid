{% layout 'theme' %}

{%- assign policy_title = shop.shipping_policy.title -%}
{%- assign policy_body = shop.shipping_policy.body -%}

{%- if request.path contains '/policies/privacy' -%}
  {%- assign policy_title = shop.privacy_policy.title -%}
  {%- assign policy_body = shop.privacy_policy.body -%}
{%- elsif request.path contains '/policies/refund' -%}
  {%- assign policy_title = shop.refund_policy.title -%}
  {%- assign policy_body = shop.refund_policy.body -%}
{%- elsif request.path contains '/policies/terms' -%}
  {%- assign policy_title = shop.terms_of_service.title -%}
  {%- assign policy_body = shop.terms_of_service.body -%}
{%- elsif request.path contains '/policies/shipping' -%}
  {%- assign policy_title = shop.shipping_policy.title -%}
  {%- assign policy_body = shop.shipping_policy.body -%}
{%- endif -%}

<main class="flex-grow pt-32 pb-stack-xl px-margin-mobile md:px-margin-desktop">
  <div class="max-w-3xl mx-auto">
    <!-- Policy Title Header -->
    <header class="text-center mb-stack-xl">
      <h1 class="font-display-lg-mobile text-display-lg-mobile md:font-display-lg md:text-display-lg text-primary uppercase tracking-wider mb-6">{{ policy_title }}</h1>
      <div class="w-12 h-px bg-outline-variant mx-auto"></div>
    </header>

    <!-- Policy Content -->
    <article class="space-y-stack-md [&>h2]:font-headline-md [&>h2]:text-headline-md [&>h2]:text-primary [&>h2]:uppercase [&>h2]:tracking-wider [&>h2]:mt-stack-md [&>h2]:mb-6 [&>p]:font-body-md [&>p]:text-body-md [&>p]:text-on-surface-variant [&>p]:leading-relaxed [&>p]:mb-6 [&>ul]:list-disc [&>ul]:ml-6 [&>ul]:space-y-3 [&>ul]:text-body-md [&>ul]:text-on-surface-variant [&>ul]:leading-relaxed [&>ol]:list-decimal [&>ol]:ml-6 [&>ol]:space-y-3 [&>ol]:text-body-md [&>ol]:text-on-surface-variant [&>ol]:leading-relaxed">
      {{ policy_body }}
    </article>
  </div>
</main>




