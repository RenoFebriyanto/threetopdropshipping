{% layout 'theme' %}

<main class="flex-grow pt-32 pb-stack-xl px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
  <article class="max-w-3xl mx-auto">
    <header class="mb-stack-lg text-center">
      <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-primary mb-6">{{ page_title }}</h1>
    </header>

    <div class="space-y-stack-md font-body-md text-body-md text-on-surface-variant leading-relaxed">
      {{ policy.body }}
    </div>
  </article>
</main>

