{% layout 'theme' %}

<main class="flex-grow pt-32 pb-stack-xl px-margin-mobile md:px-margin-desktop">
  <article class="max-w-3xl mx-auto">
    <header class="mb-stack-lg text-center">
      <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-primary mb-6">{{ page_title }}</h1>

      {%- comment -%} Last Updated (hanya tampil jika tersedia) {%- endcomment -%}
      {%- assign _updated_at = nil -%}

      {%- if policy.handle == 'shipping-policy' -%}

        {%- assign _updated_at = shop.shipping_policy.updated_at -%}
      {%- elsif policy.handle == 'refund-policy' -%}
        {%- assign _updated_at = shop.refund_policy.updated_at -%}
      {%- elsif policy.handle == 'privacy-policy' -%}
        {%- assign _updated_at = shop.privacy_policy.updated_at -%}
      {%- elsif policy.handle == 'terms-of-use' -%}
        {%- assign _updated_at = shop.terms_of_use.updated_at -%}
      {%- endif -%}

      {%- if _updated_at != blank -%}
        <p class="font-body-lg text-body-lg text-secondary">Last Updated: {{ _updated_at | date: '%B %e, %Y' }}</p>
      {%- endif -%}
    </header>

    <div class="space-y-stack-md font-body-md text-body-md text-on-surface-variant leading-relaxed [&>h2]:font-headline-md [&>h2]:text-headline-md [&>h2]:text-primary [&>h2]:mb-6 [&>h2]:mt-10 [&>p]:mb-4 [&>ul]:list-disc [&>ul]:pl-6 [&>ul]:space-y-2 [&>ul]:mb-6 [&>ol]:list-decimal [&>ol]:pl-6 [&>ol]:space-y-2 [&>ol]:mb-6">
      {{ policy.body }}
    </div>

  </article>
</main>



