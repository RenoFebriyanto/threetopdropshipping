{% layout 'theme' %}

<main class="flex-grow pt-[160px] pb-stack-xl px-margin-mobile md:px-margin-desktop">
  <div class="max-w-3xl mx-auto flex flex-col space-y-stack-md">
    <!-- Page Title -->
    <div class="text-center">
      <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-primary uppercase tracking-[0.2em] mb-4">{{ page_title }}</h1>
      <div class="w-12 h-px bg-outline-variant mx-auto"></div>
    </div>

    <!-- Content -->
    <div class="space-y-12 [>&section]:space-y-10 [&>section]:text-left [&>h2]:font-headline-md [&>h2]:text-headline-md [&>h2]:text-primary [&>p]:font-body-md [&>p]:text-body-md [&>p]:text-on-surface-variant [&>p]:leading-relaxed">

      {{ policy.body }}
    </div>


  </div>
</main>




