{% layout 'theme' %}

<main class="pt-24 pb-stack-xl">
<!-- Hero Section (Asymmetric Split-Screen) -->
<section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mt-12 md:mt-24 mb-stack-xl">
<div class="flex flex-col md:flex-row gap-gutter">
<!-- Left side (60%): Statistics -->
<div class="md:w-[60%] flex flex-col justify-center pr-0 md:pr-12">
<h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-primary mb-8 leading-tight">
                        Commitment to<br>
<span class="italic text-outline">Tomorrow.</span>
</h1>
<div class="grid grid-cols-1 sm:grid-cols-2 gap-8 mt-8 border-t border-outline-variant/30 pt-8">
<div>
<p class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-primary">98%</p>
<p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest mt-2">Organic Materials</p>
</div>
<div>
<p class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-primary">0%</p>
<p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest mt-2">Production Waste</p>
</div>
</div>
<p class="font-body-lg text-body-lg text-on-surface-variant mt-12 max-w-lg">
{{ page.content }}
</p>
</div>
<!-- Right side (40%): Texture Image -->
<div class="md:w-[40%] mt-12 md:mt-0 relative aspect-[4/5] bg-surface-container-low overflow-hidden">
<img alt="Detailed close-up of natural, unbleached organic linen fabric showing the intricate weave and subtle texture variations." class="w-full h-full object-cover transition-transform duration-1000 hover:scale-105" src="{{ 'sustainability-texture-1.jpg' | asset_url }}">
</div>
</div>
</section>
<!-- Material Pillars Section (Infographic Grid) -->
<section class="bg-surface-container-lowest py-stack-xl border-y border-outline-variant/30">
<div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
<div class="text-center mb-stack-lg">
<h2 class="font-headline-lg text-headline-lg text-primary">Core Materials</h2>
<p class="font-body-md text-body-md text-on-surface-variant mt-4 max-w-2xl mx-auto">Sourced with absolute transparency and refined to our exacting standards.</p>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-x-gutter gap-y-12">
<!-- Pillar 1 -->
<div class="flex flex-col items-start border-l border-outline-variant/30 pl-6 h-full">
<span class="material-symbols-outlined text-[32px] text-primary mb-6">recycling</span>
<h3 class="font-headline-md text-headline-md text-primary mb-4">Recycled Silk</h3>
<p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
                            Salvaged from pre-consumer waste, our silk retains the fluid drape and structural integrity of virgin fibers while eliminating the need for raw extraction.
                        </p>
</div>
<!-- Pillar 2 -->
<div class="flex flex-col items-start border-l border-outline-variant/30 pl-6 h-full">
<span class="material-symbols-outlined text-[32px] text-primary mb-6">eco</span>
<h3 class="font-headline-md text-headline-md text-primary mb-4">Organic Cotton</h3>
<p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
                            Cultivated without synthetic pesticides or fertilizers, our cotton supports soil health and provides a crisp, breathable foundation for everyday silhouettes.
                        </p>
</div>
<!-- Pillar 3 -->
<div class="flex flex-col items-start border-l border-outline-variant/30 pl-6 h-full">
<span class="material-symbols-outlined text-[32px] text-primary mb-6">grass</span>
<h3 class="font-headline-md text-headline-md text-primary mb-4">Regenerative Wool</h3>
<p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
                            Sourced from farms practicing holistic grazing, our wool sequesters carbon back into the soil, offering warmth with a net-positive environmental footprint.
                        </p>
</div>
</div>
</div>
</section>
<!-- Technical Detail Section -->
<section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-stack-xl">
<div class="grid grid-cols-1 lg:grid-cols-2 gap-gutter items-center">
<div class="order-2 lg:order-1 relative aspect-square bg-surface-container-low overflow-hidden">
<img class="w-full h-full object-cover" data-alt="A minimalist, high-end editorial photograph of a spool of unbleached thread resting on a pristine white architectural block, illuminated by soft, natural studio lighting, conveying a sense of quiet luxury and sustainable craftsmanship." src="{{ 'sustainability-thread-2.jpg' | asset_url }}">
</div>
<div class="order-1 lg:order-2 lg:pl-12">
<h2 class="font-headline-lg text-headline-lg text-primary mb-12">Supply Chain Transparency</h2>
<div class="space-y-8">
<div class="border-b border-outline-variant/30 pb-4">
<div class="flex justify-between items-baseline mb-2">
<h4 class="font-label-sm text-label-sm text-primary uppercase tracking-widest">Traceability</h4>
<span class="font-body-md text-body-md text-on-surface-variant">Tier 1 &amp; 2</span>
</div>
<p class="font-body-md text-body-md text-on-surface-variant">100% mapped and audited factories.</p>
</div>
<div class="border-b border-outline-variant/30 pb-4">
<div class="flex justify-between items-baseline mb-2">
<h4 class="font-label-sm text-label-sm text-primary uppercase tracking-widest">Water Stewardship</h4>
<span class="font-body-md text-body-md text-on-surface-variant">-40% Usage</span>
</div>
<p class="font-body-md text-body-md text-on-surface-variant">Implementation of closed-loop dyeing systems.</p>
</div>
<div class="border-b border-outline-variant/30 pb-4">
<div class="flex justify-between items-baseline mb-2">
<h4 class="font-label-sm text-label-sm text-primary uppercase tracking-widest">Carbon Emissions</h4>
<span class="font-body-md text-body-md text-on-surface-variant">Scope 1, 2, 3</span>
</div>
<p class="font-body-md text-body-md text-on-surface-variant">Committed to net-zero by 2030 across all operations.</p>
</div>
</div>
</div>
</div>
</section>
</main>