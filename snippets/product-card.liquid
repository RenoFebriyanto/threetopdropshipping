<a class="coll-card group" href="{{ product.url }}">

  {%- comment -%} ── Product Image: aspect-[4/5] ── {%- endcomment -%}
  <div class="coll-card-image-wrap">
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        width="600"
        height="750"
        loading="lazy"
        class="coll-card-img"
      >
    {%- else -%}
      <div class="coll-card-img-placeholder">
        <span class="material-symbols-outlined" style="font-size:48px">image</span>
      </div>
    {%- endif -%}
    <div class="coll-card-hover-overlay"></div>
  </div>

  {%- comment -%} ── Product Info: title+variant left, price right ── {%- endcomment -%}
  <div class="coll-card-info">
    <div>
      <h3 class="coll-card-title">{{ product.title }}</h3>
      {%- assign first_variant_title = product.variants.first.title -%}
      {%- unless first_variant_title == 'Default Title' or first_variant_title == blank -%}
        <p class="coll-card-variant">{{ first_variant_title }}</p>
      {%- endunless -%}
    </div>
    <span class="coll-card-price">{{ product.price | money }}</span>
  </div>

</a>
