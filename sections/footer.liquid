<footer class="bg-[#111111] text-[#a0a0a0] pt-20 pb-10 px-margin-mobile md:px-margin-desktop font-body-md mt-auto">
  <div class="max-w-container-max mx-auto grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8 mb-16">

    <!-- Brand Column -->
    <div class="flex flex-col gap-6">
      <a href="{{ routes.root_url }}" class="font-headline-lg text-white text-[28px] uppercase tracking-widest">
        {{ shop.name }}
      </a>
      <p class="text-sm leading-relaxed max-w-[280px]">{{ section.settings.tagline }}</p>
    </div>

    <!-- Shop Column -->
    <div class="flex flex-col gap-6">
      <h3 class="text-white font-label-sm text-label-sm uppercase tracking-widest">Shop</h3>
      <ul class="flex flex-col gap-4 text-sm">
        {% if section.settings.footer_menu != blank %}
          {% for link in linklists[section.settings.footer_menu].links %}
            <li><a href="{{ link.url }}" class="hover:text-white transition-colors duration-300">{{ link.title }}</a></li>
          {% endfor %}
        {% else %}
          <li><a href="/collections/new-arrivals" class="hover:text-white transition-colors duration-300">New Arrivals</a></li>
          <li><a href="/collections/all" class="hover:text-white transition-colors duration-300">Our Collection</a></li>
          <li><a href="/search" class="hover:text-white transition-colors duration-300">Search</a></li>
        {% endif %}
      </ul>
    </div>

    <!-- Company Column -->
    <div class="flex flex-col gap-6">
      <h3 class="text-white font-label-sm text-label-sm uppercase tracking-widest">Company</h3>
      <ul class="flex flex-col gap-4 text-sm">
        <li><a href="/pages/our-story" class="hover:text-white transition-colors duration-300">Our Story</a></li>
        <li><a href="/pages/sustainability" class="hover:text-white transition-colors duration-300">Sustainability</a></li>
        <li><a href="/pages/contact" class="hover:text-white transition-colors duration-300">Contact</a></li>
      </ul>
    </div>

    <!-- Newsletter Column -->
    <div class="flex flex-col gap-6">
      <h3 class="text-white font-label-sm text-label-sm uppercase tracking-widest">Join the Club</h3>
      <p class="text-sm">Subscribe to receive updates and access to exclusive deals.</p>
      {% form 'customer', id: 'footer-newsletter' %}
        <div class="flex items-center border-b border-[#a0a0a0] py-2 mt-2">
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input class="bg-transparent border-none outline-none w-full text-white placeholder-[#a0a0a0] text-sm" placeholder="Email Address" type="email" name="contact[email]" required autocomplete="email">
          <button type="submit" class="text-white hover:text-[#a0a0a0] transition-colors duration-300 flex-shrink-0" aria-label="Subscribe">
            <span class="material-symbols-outlined" style="font-size:20px">arrow_forward</span>
          </button>
        </div>
      {% endform %}
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="max-w-container-max mx-auto pt-8 border-t border-[#222222] flex flex-col md:flex-row justify-between items-center gap-4 text-xs font-label-sm text-label-sm tracking-wider">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    <div class="flex gap-6">
      <a href="/pages/privacy-policy" class="hover:text-white transition-colors duration-300">Privacy Policy</a>
      <a href="/pages/terms-of-use" class="hover:text-white transition-colors duration-300">Terms of Use</a>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Brand Tagline",
      "default": "Redefining modern luxury through sustainable craftsmanship and timeless design."
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer Menu",
      "default": "footer"
    }
  ]
}
{% endschema %}
