<!-- ====== HERO SECTION ====== -->
<section class="relative w-full h-screen min-h-[600px] flex items-center justify-center overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0 w-full h-full">
    {% if section.settings.bg_image != blank %}
      <img
        src="{{ section.settings.bg_image | image_url: width: 1920 }}"
        alt="{{ section.settings.title | escape }}"
        class="absolute inset-0 w-full h-full object-cover"
        width="1920" height="1080"
        loading="eager"
      >
    {% else %}
      <div class="absolute inset-0 bg-cover bg-center" style="background-image:url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1920&q=80');"></div>
    {% endif %}
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/50"></div>
  </div>

  <!-- Hero Content -->
  <div class="relative z-10 text-center px-margin-mobile md:px-margin-desktop max-w-4xl mx-auto flex flex-col items-center gap-6 md:gap-8">
    <span class="font-label-sm text-label-sm text-on-primary tracking-[0.2em] uppercase opacity-90">
      {{ section.settings.subtitle }}
    </span>
    <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-on-primary leading-tight">
      {{ section.settings.title }}
    </h1>
    <p class="font-body-lg text-body-lg text-[rgba(255,255,255,0.9)] max-w-2xl mx-auto">
      {{ section.settings.text }}
    </p>
    <div class="mt-4">
      <a href="{{ section.settings.button_link }}" class="inline-flex items-center justify-center px-10 py-4 bg-primary text-on-primary font-label-sm text-label-sm uppercase tracking-wider hover:bg-[#222222] transition-all duration-300 ease-out">
        {{ section.settings.button_label }}
      </a>
    </div>
  </div>
</section>

<!-- ====== FEATURED COLLECTION SECTION ====== -->
<section style="padding: 120px 80px; background-color: #f9f9f9; max-width: 1440px; margin: 0 auto;">
  <div style="margin-bottom: 48px;">
    <h2 style="font-family: 'Bodoni Moda', serif; font-size: 32px; font-weight: 400; letter-spacing: 0.05em; text-transform: uppercase; color: #1a1c1c; margin: 0;">{{ section.settings.collection_title }}</h2>
  </div>
  <div class="home-product-grid">
    {% assign featured = collections[section.settings.collection] %}
    {% assign products_source = featured.products %}
    {% if featured == blank or featured.products.size == 0 %}
      {% assign products_source = collections.all.products %}
    {% endif %}
    {% for product in products_source limit: 4 %}
      <div class="home-card">
        <div style="position: relative; aspect-ratio: 3/4; overflow: hidden; background-color: #eeeeee;">
          <a href="{{ product.url }}">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | default: product.title | escape }}"
                class="home-card-image"
                width="600" height="800" loading="lazy"
              >
            {% else %}
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#cfc4c5;">
                <span class="material-symbols-outlined" style="font-size:48px">image</span>
              </div>
            {% endif %}
          </a>
          <div class="home-card-overlay">
            <form method="post" action="/cart/add" style="width:100%;">
              <input type="hidden" name="id" value="{{ product.variants.first.id }}">
              <input type="hidden" name="quantity" value="1">
              <button type="submit" style="width:100%;padding:12px;background:#1a1c1c;color:#ffffff;font-family:'Inter',sans-serif;font-size:12px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;border:none;cursor:pointer;">
                Quick Add
              </button>
            </form>
          </div>
        </div>
        <div class="home-card-info">
          <h3 class="home-card-title">
            <a href="{{ product.url }}" style="color:inherit;text-decoration:none;">{{ product.title }}</a>
          </h3>
          <p class="home-card-price">{{ product.price | money }}</p>
          <form method="post" action="/cart/add" style="display:none;" class="home-card-mobile-add">
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
            <input type="hidden" name="quantity" value="1">
            <button type="submit" style="font-family:'Inter',sans-serif;font-size:12px;font-weight:500;letter-spacing:0.1em;color:#1a1c1c;text-decoration:underline;background:none;border:none;cursor:pointer;padding:0;margin-top:8px;">Quick Add</button>
          </form>
        </div>
      </div>
    {% endfor %}
  </div>
  <div style="margin-top: 48px; text-align: center;">
    <a href="{{ section.settings.button_link | default: '/collections/all' }}" style="display:inline-flex;align-items:center;justify-content:center;padding:16px 40px;border:1px solid #1a1c1c;color:#1a1c1c;font-family:'Inter',sans-serif;font-size:12px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;transition:background 0.3s ease, color 0.3s ease;">
      View All
    </a>
  </div>
</section>

<!-- ====== BRAND STORY SECTION ====== -->
<section class="grid grid-cols-1 md:grid-cols-2 min-h-[600px] overflow-hidden">
  <div class="relative aspect-[3/4] md:aspect-auto h-full">
    {% if section.settings.story_image != blank %}
      <img src="{{ section.settings.story_image | image_url: width: 900 }}" alt="{{ section.settings.story_heading | escape }}" class="absolute inset-0 w-full h-full object-cover" width="900" height="1200" loading="lazy">
    {% else %}
      <div class="absolute inset-0 bg-surface-container flex items-center justify-center">
        <span class="material-symbols-outlined text-outline-variant" style="font-size:64px">image</span>
      </div>
    {% endif %}
  </div>
  <div class="flex flex-col justify-center p-12 md:p-margin-desktop bg-[#FBF9F6] text-on-surface">
    <div class="max-w-xl">
      <h2 class="font-headline-lg text-headline-lg uppercase tracking-wider mb-8">{{ section.settings.story_heading }}</h2>
      <div class="flex flex-col gap-6 font-body-md text-on-surface-variant">
        {{ section.settings.story_text }}
      </div>
      {% if section.blocks.size > 0 %}
        <div class="mt-12 pt-8 border-t border-outline-variant flex flex-wrap gap-8">
          {% for block in section.blocks %}
            <div class="flex items-center gap-2" {{ block.shopify_attributes }}>
              <span class="material-symbols-outlined" style="font-size:20px">{{ block.settings.icon }}</span>
              <span class="font-label-sm text-label-sm uppercase tracking-widest">{{ block.settings.label }}</span>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<!-- ====== CURATED ESSENTIALS TEASER SECTION ====== -->
<section style="padding: 120px 80px; background-color: #f9f9f9; text-align: center;">
  <h2 style="font-family: 'Bodoni Moda', serif; font-size: 32px; font-weight: 400; color: #1a1c1c; margin: 0 0 24px;">{{ section.settings.teaser_heading }}</h2>
  <p style="font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 400; line-height: 1.6; color: #4c4546; max-width: 672px; margin: 0 auto;">
    {{ section.settings.teaser_text }}
  </p>
  {% if section.settings.teaser_button_label != blank %}
    <div class="mt-8">
      <a href="{{ section.settings.teaser_button_link | default: '/collections/all' }}" class="inline-flex items-center justify-center px-10 py-4 bg-primary text-on-primary font-label-sm text-label-sm uppercase tracking-wider hover:bg-[#222222] transition-all duration-300 ease-out">
        {{ section.settings.teaser_button_label }}
      </a>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Home Page",
  "settings": [
    {
      "type": "header",
      "content": "Hero Section"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Hero Background Image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Hero Subtitle",
      "default": "Summer Collection 2026"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Hero Heading",
      "default": "Elegance in Every Thread"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Hero Body Text",
      "default": "Discover our latest collection crafted from 100% sustainable premium silk and organic cotton."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Featured Collection"
    },
    {
      "type": "text",
      "id": "collection_title",
      "label": "Section Heading",
      "default": "Curated Pieces"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to Feature"
    },
    {
      "type": "header",
      "content": "Brand Story"
    },
    {
      "type": "image_picker",
      "id": "story_image",
      "label": "Brand Story Image"
    },
    {
      "type": "text",
      "id": "story_heading",
      "label": "Story Heading",
      "default": "Crafted for Longevity"
    },
    {
      "type": "richtext",
      "id": "story_text",
      "label": "Story Text",
      "default": "<p>At Lumina, we believe true luxury is defined by the endurance of both style and substance.</p>"
    },
    {
      "type": "header",
      "content": "Curated Essentials Teaser"
    },
    {
      "type": "text",
      "id": "teaser_heading",
      "label": "Teaser Heading",
      "default": "Curated Essentials"
    },
    {
      "type": "text",
      "id": "teaser_text",
      "label": "Teaser Subheading",
      "default": "Our commitment to refined aesthetics continues below."
    },
    {
      "type": "text",
      "id": "teaser_button_label",
      "label": "Teaser Button Label (leave blank to hide)",
      "default": ""
    },
    {
      "type": "url",
      "id": "teaser_button_link",
      "label": "Teaser Button Link"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Material Icon Name",
          "default": "eco"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Badge Text",
          "default": "100% Organic Cotton"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Page",
      "blocks": [
        { "type": "badge", "settings": { "icon": "eco",           "label": "100% Organic Cotton" } },
        { "type": "badge", "settings": { "icon": "handshake",     "label": "Ethically Made" } },
        { "type": "badge", "settings": { "icon": "local_shipping","label": "Complimentary Shipping" } }
      ]
    }
  ]
}
{% endschema %}
