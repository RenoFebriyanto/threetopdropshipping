<div class="collection-page">

  {%- comment -%} ─── Hero Header ─── {%- endcomment -%}
  <header class="collection-header">
    <h1 class="collection-title">Our Collection</h1>
    <div class="collection-description">
      {%- if collection.description != blank -%}
        {{ collection.description }}
      {%- else -%}
        Curated essentials designed for the modern wardrobe. Explore a selection defined by architectural precision and understated luxury.
      {%- endif -%}
    </div>
  </header>

  {%- comment -%} ─── Two-Column Layout: Sidebar + Grid ─── {%- endcomment -%}
  <div class="collection-layout">

    {%- comment -%} ─── Left Sidebar Filters ─── {%- endcomment -%}
    <aside class="collection-sidebar">
      <form id="CollectionFiltersForm" class="collection-filters-form">

        {%- if collection.sort_by -%}
          <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
        {%- endif -%}

        {%- for filter in collection.filters -%}
          <div class="collection-filter-group">
            <h3 class="filter-label">{{ filter.label }}</h3>

            {%- if filter.type == 'list' -%}

              {%- comment -%} Size Filter — Square Buttons {%- endcomment -%}
              {%- if filter.label == 'Size' or filter.label == 'Ukuran' -%}
                <div class="filter-size-grid">
                  {%- for filter_value in filter.values -%}
                    <label class="size-btn-label">
                      <input
                        type="checkbox"
                        name="{{ filter_value.param_name }}"
                        value="{{ filter_value.value }}"
                        class="sr-only"
                        {% if filter_value.active %}checked{% endif %}
                        onchange="this.form.submit()"
                      >
                      <span class="size-btn{% if filter_value.active %} active{% endif %}">
                        {{ filter_value.label }}
                      </span>
                    </label>
                  {%- endfor -%}
                </div>

              {%- comment -%} Color Filter — Circular Swatches {%- endcomment -%}
              {%- elsif filter.label == 'Color' or filter.label == 'Colour' or filter.label == 'Warna' -%}
                <div class="filter-swatch-grid">
                  {%- for filter_value in filter.values -%}
                    <label class="swatch-label">
                      <input
                        type="checkbox"
                        name="{{ filter_value.param_name }}"
                        value="{{ filter_value.value }}"
                        class="sr-only"
                        {% if filter_value.active %}checked{% endif %}
                        onchange="this.form.submit()"
                      >
                      <span
                        class="color-swatch{% if filter_value.active %} active{% endif %}"
                        aria-label="{{ filter_value.label }}"
                        title="{{ filter_value.label }}"
                        style="background-color: {{ filter_value.label | downcase | replace: ' ', '' }};"
                      ></span>
                    </label>
                  {%- endfor -%}
                </div>

              {%- comment -%} Category / Generic List Filter — Checkboxes {%- endcomment -%}
              {%- else -%}
                <ul class="filter-checkbox-list">
                  {%- for filter_value in filter.values -%}
                    <li>
                      <label class="filter-checkbox-label{% if filter_value.active %} active{% endif %}">
                        <input
                          type="checkbox"
                          name="{{ filter_value.param_name }}"
                          value="{{ filter_value.value }}"
                          class="filter-checkbox-input"
                          {% if filter_value.active %}checked{% endif %}
                          onchange="this.form.submit()"
                        >
                        <span class="filter-checkbox-text">{{ filter_value.label }}</span>
                      </label>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}

            {%- endif -%}

            {%- comment -%} Price Range Filter {%- endcomment -%}
            {%- if filter.type == 'price_range' -%}
              <div class="filter-price-range">
                <div class="filter-price-input-wrap">
                  <span class="filter-price-symbol">{{ cart.currency.symbol }}</span>
                  <input
                    type="number"
                    name="{{ filter.min_value.param_name }}"
                    {% if filter.min_value.value %}value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                    placeholder="0"
                    min="0"
                    max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                    class="filter-price-input"
                    onchange="this.form.submit()"
                  >
                </div>
                <span class="filter-price-separator">—</span>
                <div class="filter-price-input-wrap">
                  <span class="filter-price-symbol">{{ cart.currency.symbol }}</span>
                  <input
                    type="number"
                    name="{{ filter.max_value.param_name }}"
                    {% if filter.max_value.value %}value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                    placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                    min="0"
                    max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                    class="filter-price-input"
                    onchange="this.form.submit()"
                  >
                </div>
              </div>
            {%- endif -%}

          </div>
        {%- endfor -%}

      </form>
    </aside>

    {%- comment -%} ─── Right: Product Grid ─── {%- endcomment -%}
    <div class="collection-grid-area">
      {% paginate collection.products by section.settings.products_per_page %}

        {%- comment -%} Empty state {%- endcomment -%}
        {%- assign products_to_loop = collection.products -%}
        {%- if products_to_loop.size == 0 and collection.handle == blank -%}
          {%- assign products_to_loop = collections.all.products -%}
        {%- endif -%}

        {%- if products_to_loop.size > 0 -%}
          <div class="col-grid--3">
            {%- for product in products_to_loop limit: section.settings.products_per_page -%}
              {% render 'product-card', product: product %}
            {%- endfor -%}
          </div>
        {%- else -%}
          <div class="collection-empty">
            <p>No products found in this collection.</p>
          </div>
        {%- endif -%}

        {%- comment -%} ─── Load More Button ─── {%- endcomment -%}
        {%- if paginate.next -%}
          <div class="load-more-wrap">
            <a href="{{ paginate.next.url }}" class="btn-load-more" id="collection-load-more">
              Load More
            </a>
          </div>
        {%- endif -%}

      {% endpaginate %}
    </div>

  </div>{%- comment -%} /.collection-layout {%- endcomment -%}
</div>{%- comment -%} /.collection-page {%- endcomment -%}

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 12
    }
  ]
}
{% endschema %}
