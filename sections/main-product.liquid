<div class="py-8 pt-8 pb-stack-xl px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto w-full">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-y-12 md:gap-gutter">

    <!-- ====== IMAGE GALLERY (Left) ====== -->
    <div class="md:col-span-7 lg:col-span-8 flex flex-col gap-4">

      <!-- Main Image -->
      <div class="w-full aspect-[4/5] bg-surface-container-high overflow-hidden group" id="pdp-main-image-wrap">
        {% if product.featured_media %}
          <img
            id="pdp-main-image"
            src="{{ product.featured_media | image_url: width: 900 }}"
            alt="{{ product.featured_media.alt | default: product.title | escape }}"
            width="900"
            height="1125"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-in-out"
            loading="eager"
          >
        {% endif %}
      </div>

      <!-- Thumbnail Grid -->
      {% if product.media.size > 1 %}
        <div class="grid grid-cols-4 gap-3 mt-2">
          {% for media in product.media %}
            <button
              type="button"
              class="aspect-square bg-surface-container-high overflow-hidden border-2 transition-all duration-200 {% if forloop.first %}border-primary{% else %}border-transparent hover:border-outline-variant{% endif %}"
              onclick="document.getElementById('pdp-main-image').src = '{{ media | image_url: width: 900 }}'; document.querySelectorAll('[data-thumb]').forEach(el => el.classList.remove('border-primary')); this.classList.add('border-primary');"
              data-thumb
            >
              <img
                src="{{ media | image_url: width: 200 }}"
                alt="{{ media.alt | default: product.title | escape }}"
                width="200"
                height="200"
                loading="lazy"
                class="w-full h-full object-cover"
              >
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- ====== PRODUCT INFO (Right, Sticky) ====== -->
    <div class="md:col-span-5 lg:col-span-4">
      <div class="md:sticky md:top-28 flex flex-col gap-8">

        <!-- Title & Price -->
        <div class="flex flex-col gap-2">
          <h1 class="font-headline-lg text-headline-lg text-primary">{{ product.title }}</h1>
          <div class="flex items-center gap-2 mt-1">
            <div class="flex text-primary">
              <span class="material-symbols-outlined" style="font-size:18px; font-variation-settings:'FILL' 1">star</span>
              <span class="material-symbols-outlined" style="font-size:18px; font-variation-settings:'FILL' 1">star</span>
              <span class="material-symbols-outlined" style="font-size:18px; font-variation-settings:'FILL' 1">star</span>
              <span class="material-symbols-outlined" style="font-size:18px; font-variation-settings:'FILL' 1">star</span>
              <span class="material-symbols-outlined" style="font-size:18px; font-variation-settings:'FILL' 1">star</span>
            </div>
            <span class="font-body-md text-label-sm text-on-surface-variant">4.8 (124 reviews)</span>
          </div>
          <p class="font-body-lg text-body-lg text-on-surface-variant mt-2" id="pdp-price">
            {% if product.price_varies %}
              From {{ product.price_min | money }}
            {% else %}
              {{ product.price | money }}
            {% endif %}
          </p>
          {% if product.compare_at_price > product.price %}
            <p class="font-label-sm text-label-sm text-error line-through">{{ product.compare_at_price | money }}</p>
          {% endif %}
        </div>

        <!-- Add to Cart Form -->
        {% form 'product', product, id: 'pdp-form', class: 'flex flex-col gap-6' %}

          <!-- Variant Selectors -->
          {% unless product.has_only_default_variant %}
            {% for option in product.options_with_values %}
              <div class="flex flex-col gap-3">
                <div class="flex justify-between items-center">
                  <span class="font-label-sm text-label-sm text-primary uppercase tracking-widest">{{ option.name }}</span>
                  {% if option.name == 'Size' %}
                    <a href="#" class="font-label-sm text-label-sm text-on-surface-variant underline hover:text-primary transition-colors">Size Guide</a>
                  {% endif %}
                </div>
                {% if option.name == 'Color' or option.name == 'Colour' %}
                  <div class="flex flex-wrap gap-3">
                    {% for value in option.values %}
                      <label class="cursor-pointer">
                        <input type="radio" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" class="sr-only peer" {% if forloop.first %}checked{% endif %}>
                        <span class="w-8 h-8 rounded-full border-2 border-transparent peer-checked:border-primary block" style="background-color: {{ value | downcase }};"></span>
                        <span class="sr-only">{{ value }}</span>
                      </label>
                    {% endfor %}
                  </div>
                {% else %}
                  <div class="grid grid-cols-4 gap-2">
                    {% for value in option.values %}
                      <label class="cursor-pointer">
                        <input type="radio" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" class="sr-only peer" {% if forloop.first %}checked{% endif %}>
                        <span class="block py-3 border text-center font-label-sm text-label-sm transition-colors duration-200 border-outline-variant text-on-surface peer-checked:border-primary peer-checked:text-primary hover:border-primary">{{ value }}</span>
                      </label>
                    {% endfor %}
                  </div>
                {% endif %}
              </div>
            {% endfor %}
          {% endunless %}

          <!-- Hidden Variant ID (updated by JS) -->
          <select name="id" id="pdp-variant-select" class="sr-only" aria-label="Product variant">
            {% for variant in product.variants %}
              <option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>
                {{ variant.title }}
              </option>
            {% endfor %}
          </select>

          <!-- Add to Cart Button -->
          <div class="flex flex-col gap-4 pt-2">
            <button
              type="submit"
              id="pdp-submit"
              class="w-full bg-primary text-on-primary py-4 font-label-sm text-label-sm uppercase tracking-widest hover:bg-[#222222] transition-colors duration-300 disabled:opacity-50 disabled:cursor-not-allowed"
              {% unless product.available %}disabled{% endunless %}
            >
              {% if product.available %}Add to Cart{% else %}Sold Out{% endif %}
            </button>

            {% if product.variants.first.inventory_quantity > 0 and product.variants.first.inventory_quantity <= 5 %}
              <p class="font-body-md text-label-sm text-error flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-error inline-block"></span>
                Only {{ product.variants.first.inventory_quantity }} left in stock
              </p>
            {% endif %}
          </div>
        {% endform %}

        <!-- Trust Badges -->
        <div class="grid grid-cols-3 gap-2 pt-6 border-t border-outline-variant">
          <div class="flex flex-col items-center text-center gap-2">
            <span class="material-symbols-outlined text-on-surface-variant" style="font-size:22px">local_shipping</span>
            <span class="font-label-sm text-[10px] uppercase tracking-tighter text-on-surface-variant">Free Shipping</span>
          </div>
          <div class="flex flex-col items-center text-center gap-2">
            <span class="material-symbols-outlined text-on-surface-variant" style="font-size:22px">assignment_return</span>
            <span class="font-label-sm text-[10px] uppercase tracking-tighter text-on-surface-variant">30-Day Returns</span>
          </div>
          <div class="flex flex-col items-center text-center gap-2">
            <span class="material-symbols-outlined text-on-surface-variant" style="font-size:22px">verified_user</span>
            <span class="font-label-sm text-[10px] uppercase tracking-tighter text-on-surface-variant">Secure Checkout</span>
          </div>
        </div>

        <!-- Accordions -->
        <div class="flex flex-col border-t border-outline-variant">
          <details class="group border-b border-outline-variant py-4" open>
            <summary class="flex justify-between items-center cursor-pointer list-none font-label-sm text-label-sm text-primary uppercase tracking-widest">
              Product Details
              <span class="material-symbols-outlined accordion-icon" style="font-size:20px">expand_more</span>
            </summary>
            <div class="pt-4 font-body-md text-body-md text-on-surface-variant">
              {{ product.description }}
            </div>
          </details>
          <details class="group border-b border-outline-variant py-4">
            <summary class="flex justify-between items-center cursor-pointer list-none font-label-sm text-label-sm text-primary uppercase tracking-widest">
              Shipping &amp; Returns
              <span class="material-symbols-outlined accordion-icon" style="font-size:20px">expand_more</span>
            </summary>
            <div class="pt-4 font-body-md text-body-md text-on-surface-variant">
              <p>{{ section.settings.shipping_text }}</p>
            </div>
          </details>
        </div>

      </div>
    </div>
  </div>

  <!-- You Might Also Like -->
  <section class="mt-stack-xl pt-stack-lg border-t border-outline-variant">
    <h2 class="font-headline-md text-headline-md text-primary mb-12 text-center md:text-left">You Might Also Like</h2>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-gutter">
      {% for related in collections.all.products limit: 4 %}
        {% unless related.id == product.id %}
          {% render 'product-card', product: related %}
        {% endunless %}
      {% endfor %}
    </div>
  </section>
</div>

<!-- Variant JS: keeps the hidden select in sync with radio buttons -->
<script>
(function () {
  var form = document.getElementById('pdp-form');
  if (!form) return;

  var variantSelect = document.getElementById('pdp-variant-select');
  var priceEl = document.getElementById('pdp-price');
  var submitBtn = document.getElementById('pdp-submit');

  var productData = {{ product.variants | json }};

  function getSelectedOptions() {
    var opts = {};
    form.querySelectorAll('input[type="radio"]:checked').forEach(function (radio) {
      var optName = radio.name.replace('options[', '').replace(']', '');
      opts[optName] = radio.value;
    });
    return opts;
  }

  function findVariant(selected) {
    return productData.find(function (v) {
      return v.options.every(function (opt, i) {
        var key = Object.keys(selected)[i];
        return selected[key] === opt;
      });
    });
  }

  function updateVariant() {
    var selected = getSelectedOptions();
    var variant = findVariant(selected);
    if (!variant) return;
    variantSelect.value = variant.id;
    if (priceEl) {
      priceEl.textContent = new Intl.NumberFormat('en-US', { style: 'currency', currency: '{{ cart.currency.iso_code }}' }).format(variant.price / 100);
    }
    if (submitBtn) {
      if (variant.available) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Add to Cart';
      } else {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sold Out';
      }
    }
  }

  form.querySelectorAll('input[type="radio"]').forEach(function (radio) {
    radio.addEventListener('change', updateVariant);
  });
})();
</script>

{% schema %}
{
  "name": "Main Product",
  "settings": [
    {
      "type": "textarea",
      "id": "shipping_text",
      "label": "Shipping & Returns Text",
      "default": "Complimentary worldwide shipping on all orders. Returns accepted within 30 days of purchase."
    }
  ]
}
{% endschema %}
