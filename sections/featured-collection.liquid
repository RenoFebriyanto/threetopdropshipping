<section class="py-stack-xl bg-background px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
  <div class="mb-12">
    <h2 class="font-headline-lg text-headline-lg text-primary uppercase tracking-wider">{{ section.settings.title }}</h2>
  </div>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
    {% if section.settings.collection != blank %}
      {% for product in collections[section.settings.collection].products limit: 4 %}
        {% render 'product-card', product: product %}
      {% endfor %}
    {% else %}
      {% for i in (1..4) %}
        <div class="group flex flex-col gap-4">
          <div class="relative aspect-[3/4] overflow-hidden bg-surface-container flex items-center justify-center">
            <span class="text-on-surface-variant font-label-sm uppercase">Product {{ i }}</span>
          </div>
          <div class="flex flex-col gap-1">
            <h3 class="font-body-md text-on-surface">Example Product</h3>
            <p class="font-label-sm text-on-surface-variant">$240.00</p>
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Curated Pieces"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
