<header class="fixed top-0 w-full z-50 transition-all duration-300 ease-in-out glass-nav border-b border-transparent">
<nav aria-label="Global" class="flex justify-between items-center w-full px-margin-desktop h-20 max-w-container-max mx-auto hidden md:flex">
  <!-- Left: Logo -->
  <div class="flex items-center flex-1">
    <a href="/" class="font-headline-md text-primary hover:opacity-80 transition-opacity">Lumina</a>
  </div>
  
  <!-- Center: Navigation Links -->
  <div class="flex gap-8 items-center justify-center flex-1">
    <a class="font-label-sm text-label-sm text-on-surface-variant dark:text-outline-variant link-hover-underline hover:text-primary dark:hover:text-on-surface transition-colors duration-300" href="/collections/new-arrivals">New Arrivals</a>
    <a class="font-label-sm text-label-sm text-on-surface-variant dark:text-outline-variant link-hover-underline hover:text-primary dark:hover:text-on-surface transition-colors duration-300" href="/collections/all">Our Collection</a>
    <a class="font-label-sm text-label-sm text-on-surface-variant dark:text-outline-variant link-hover-underline hover:text-primary dark:hover:text-on-surface transition-colors duration-300" href="/pages/contact">Contact</a>
  </div>
  
  <!-- Right: Actions -->
  <div class="flex gap-6 items-center flex-1 justify-end">
    <button aria-label="Search" class="text-primary dark:text-on-surface hover:text-on-surface-variant transition-colors duration-300 cursor-pointer border-none bg-transparent p-0">
      <span class="material-symbols-outlined text-[24px]">search</span>
    </button>
    <button id="cart-icon-desktop" aria-label="Shopping Bag" class="text-primary dark:text-on-surface hover:text-on-surface-variant transition-colors duration-300 cursor-pointer border-none bg-transparent p-0">
      <span class="material-symbols-outlined text-[24px]">shopping_bag</span>
    </button>
  </div>
</nav>

<!-- Mobile Nav -->
<nav class="flex md:hidden justify-between items-center w-full px-margin-mobile h-16">
  <div class="flex items-center flex-1">
    <button aria-label="Menu" class="text-primary border-none bg-transparent p-0">
      <span class="material-symbols-outlined">menu</span>
    </button>
  </div>
  
  <div class="flex items-center justify-center flex-1">
    <a href="/" class="font-headline-md text-primary hover:opacity-80 transition-opacity">Lumina</a>
  </div>
  
  <div class="flex items-center flex-1 justify-end">
    <button id="cart-icon-mobile" aria-label="Shopping Bag" class="text-primary border-none bg-transparent p-0 cursor-pointer">
      <span class="material-symbols-outlined text-[24px]">shopping_bag</span>
    </button>
  </div>
</nav>
</header>
<div class="h-20"></div>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
